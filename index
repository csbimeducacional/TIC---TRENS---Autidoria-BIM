<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kick-off | Consultoria BIM — TIC TRENS</title>
<style>
  :root{
    --navy:#1E2761;
    --navy-dark:#11163E;
    --ice:#CADCFC;
    --accent:#4FD1C5;
    --muted:#7C88B8;
    --card:#F4F7FE;
    --text:#1E2761;
    /* CSBIM brand */
    --cs-navy:#001F2E;
    --cs-blue:#005C8B;
    --cs-cyan:#00A5DD;
    --cs-bright:#0A84FF;
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  html,body{height:100%;}
  body{
    font-family:"Calibri","Segoe UI",Arial,sans-serif;
    background:var(--navy);
    color:var(--text);
    overflow:hidden;
  }
  .deck{
    height:100vh;
    width:100vw;
    position:relative;
  }
  .slide{
    position:absolute;
    top:0;left:0;
    width:100%;height:100%;
    display:flex;
    flex-direction:column;
    padding:5vh 6vw;
    opacity:0;
    visibility:hidden;
    transform:translateY(24px);
    transition:opacity .5s ease, transform .5s ease;
  }
  .slide.active{
    opacity:1;
    visibility:visible;
    transform:translateY(0);
  }
  .slide.light{ background:#FFFFFF; color:var(--text); }
  .slide.dark{ background:var(--navy); color:#FFFFFF; }

  /* decorative circles */
  .circle{
    position:absolute;
    border-radius:50%;
    background:var(--navy-dark);
    z-index:0;
  }
  .light .circle{ background:var(--card); }

  h1{
    font-family:Cambria, "Times New Roman", serif;
    font-size:clamp(2.4rem, 5vw, 3.4rem);
    font-weight:700;
    line-height:1.1;
    position:relative; z-index:1;
  }
  .eyebrow{
    font-size:.85rem;
    letter-spacing:.25em;
    font-weight:700;
    color:var(--accent);
    text-transform:uppercase;
    margin-bottom:.6rem;
    position:relative; z-index:1;
  }
  .subtitle{
    font-size:1.25rem;
    margin-top:.6rem;
    color:var(--ice);
    position:relative; z-index:1;
  }
  .light .subtitle{ color:var(--muted); }

  .content{
    position:relative; z-index:1;
    flex:1;
    display:flex;
    flex-direction:column;
    justify-content:center;
    margin-top:2vh;
  }

  /* progress / nav */
  .nav{
    position:fixed;
    bottom:4vh;
    left:6vw;
    right:6vw;
    display:flex;
    align-items:center;
    justify-content:space-between;
    z-index:50;
    font-size:.85rem;
    color:var(--ice);
  }
  .light .nav{ color:var(--muted); }
  .dots{ display:flex; gap:.5rem; }
  .dot{
    width:.55rem; height:.55rem; border-radius:50%;
    background:rgba(255,255,255,.25);
    cursor:pointer;
    transition:background .25s, transform .25s;
  }
  .light .dot{ background:rgba(30,39,97,.18); }
  .dot.on{ background:var(--accent); transform:scale(1.25); }

  .arrows{ display:flex; gap:.6rem; }
  .arrow-btn{
    width:42px;height:42px;border-radius:50%;
    border:1.5px solid rgba(255,255,255,.35);
    background:transparent;
    color:inherit;
    cursor:pointer;
    display:flex;align-items:center;justify-content:center;
    font-size:1.1rem;
    transition:background .2s, border-color .2s;
  }
  .light .arrow-btn{ border-color:rgba(30,39,97,.25); }
  .arrow-btn:hover{ background:rgba(255,255,255,.12); border-color:var(--accent); }
  .light .arrow-btn:hover{ background:rgba(79,209,197,.12); }

  /* === Capa CSBIM (cover) === */
  .slide.cover{
    background:
      radial-gradient(1100px 620px at 82% -12%, rgba(0,165,221,.22), transparent 60%),
      radial-gradient(900px 520px at -8% 112%, rgba(0,92,139,.40), transparent 55%),
      linear-gradient(135deg, #00131D 0%, #001F2E 46%, #00314A 100%);
    color:#fff;
    overflow:hidden;
    justify-content:flex-start;
  }
  .cover .poly{ position:absolute; z-index:0; pointer-events:none; }
  .cover .poly.tr{ top:-60px; right:-60px; width:460px; opacity:.55; }
  .cover .poly.bl{ bottom:-90px; left:-70px; width:360px; opacity:.32; transform:rotate(180deg); }

  .cover-top{
    position:relative; z-index:2;
    display:flex; align-items:center; gap:1.1rem;
    margin-bottom:auto;
  }
  .brand-chip{
    background:#fff;
    border-radius:14px;
    padding:.85rem 1.25rem;
    display:flex; flex-direction:column; align-items:center; gap:.45rem;
    box-shadow:0 14px 34px rgba(0,0,0,.34);
  }
  .brand-chip img{ width:auto; display:block; object-fit:contain; }
  .brand-chip.cs img{ height:56px; }
  .brand-chip.tt img{ height:38px; }
  .brand-cap{
    font-size:.6rem; letter-spacing:.22em; font-weight:700;
    text-transform:uppercase; color:var(--cs-blue);
  }
  .brand-link{
    display:flex; flex-direction:column; align-items:center; gap:.2rem;
    color:var(--cs-cyan);
  }
  .brand-link svg{ width:26px; height:26px; }
  .brand-link span{ font-size:.58rem; letter-spacing:.16em; font-weight:700; text-transform:uppercase; color:var(--ice); }

  .cover .eyebrow{ color:var(--cs-cyan); margin-top:3.2vh; }
  .cover h1{
    font-size:clamp(2.6rem, 5.6vw, 3.9rem);
    letter-spacing:.5px;
  }
  .cover h1 .hl{ color:var(--cs-cyan); }
  .cover .title-rule{
    width:84px; height:5px; border-radius:4px;
    background:linear-gradient(90deg, var(--cs-cyan), var(--cs-bright));
    margin:1.1rem 0 1.2rem; position:relative; z-index:1;
  }
  .cover .subtitle{
    color:#DCEFFA; font-size:1.3rem; margin-top:0;
    position:relative; z-index:1;
  }
  .cover .subtitle b{ color:#fff; }

  .cover-badges{
    display:flex; gap:1rem; flex-wrap:wrap;
    margin-top:1.8rem; position:relative; z-index:1;
  }
  .cover-badge{
    display:flex; align-items:center; gap:.6rem;
    background:rgba(255,255,255,.08);
    border:1px solid rgba(0,165,221,.35);
    border-radius:999px;
    padding:.55rem 1.1rem;
    font-size:.95rem; color:#EAF6FC;
    backdrop-filter:blur(2px);
  }
  .cover-badge svg{ width:18px; height:18px; color:var(--cs-cyan); flex-shrink:0; }

  .cover-welcome{
    margin-top:auto;
    margin-bottom:6vh;
    background:rgba(0,49,74,.55);
    border-left:4px solid var(--cs-cyan);
    border-radius:12px;
    padding:1.25rem 1.7rem;
    font-style:italic;
    color:#DCEFFA;
    font-size:1.05rem;
    position:relative; z-index:1;
    max-width:920px;
  }

  @media (max-width:760px){
    .cover-top{ flex-wrap:wrap; gap:.8rem; }
    .brand-chip.cs img{ height:46px; }
    .brand-chip.tt img{ height:30px; }
  }

  /* === Slide 1: Title === */
  .badge-row{
    display:flex; gap:2.2rem; margin-top:2.2rem; position:relative; z-index:1;
    flex-wrap:wrap;
  }
  .badge{
    display:flex; align-items:center; gap:.7rem;
    font-size:1.05rem;
  }
  .badge svg{ width:24px; height:24px; flex-shrink:0; }
  .welcome-card{
    margin-top:auto;
    background:var(--navy-dark);
    border-radius:14px;
    padding:1.4rem 1.8rem;
    font-style:italic;
    color:var(--ice);
    font-size:1.05rem;
    position:relative; z-index:1;
    max-width:900px;
  }

  /* === Agenda === */
  .agenda-list{ display:flex; flex-direction:column; gap:1rem; margin-top:1rem;}
  .agenda-item{
    display:flex; align-items:center; gap:1.4rem;
    background:var(--card);
    border-radius:14px;
    padding:1.2rem 1.6rem;
    box-shadow:0 4px 16px rgba(30,39,97,.06);
  }
  .agenda-icon{
    width:48px;height:48px;border-radius:50%;
    background:var(--navy);
    display:flex;align-items:center;justify-content:center;
    flex-shrink:0;
  }
  .agenda-icon svg{ width:24px;height:24px;color:#fff; }
  .agenda-icon.accent svg{ color:var(--accent); }
  .agenda-text h3{ font-size:1.15rem; font-weight:700; color:var(--navy); }
  .agenda-text p{ font-size:.92rem; color:var(--muted); margin-top:.2rem; }
  .agenda-num{
    margin-left:auto;
    font-family:Cambria, serif;
    font-size:1.9rem; font-weight:700;
    color:var(--ice);
  }

  /* === Estrutura (2 etapas) === */
  .etapas{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:1.4rem;
    margin-top:1rem;
  }
  .etapa-card{
    border-radius:16px;
    padding:1.8rem;
    display:flex;
    flex-direction:column;
  }
  .etapa-card.primary{
    background:var(--navy);
    color:#fff;
    box-shadow:0 10px 30px rgba(30,39,97,.25);
  }
  .etapa-card.secondary{
    background:var(--card);
    color:var(--text);
  }
  .etapa-head{ display:flex; align-items:center; gap:.8rem; margin-bottom:.4rem;}
  .etapa-head svg{ width:30px; height:30px; }
  .etapa-tag{ font-size:.78rem; letter-spacing:.2em; font-weight:700; }
  .etapa-card.primary .etapa-tag{ color:var(--accent); }
  .etapa-card.secondary .etapa-tag{ color:var(--navy); }
  .etapa-card h3{ font-family:Cambria, serif; font-size:1.45rem; margin-top:.2rem; }
  .etapa-days{
    align-self:flex-end;
    font-size:.85rem;
    margin-top:-2.4rem;
    color:var(--ice);
  }
  .etapa-desc{ font-size:.95rem; margin:1rem 0; line-height:1.5; }
  .etapa-card.primary .etapa-desc{ color:var(--ice); }
  .etapa-card.secondary .etapa-desc{ color:var(--text); opacity:.85; }
  .etapa-bullets{ list-style:none; display:flex; flex-direction:column; gap:.5rem; font-size:.92rem; }
  .etapa-bullets li{ display:flex; gap:.6rem; align-items:flex-start; }
  .etapa-bullets li::before{
    content:"";
    width:7px;height:7px;border-radius:50%;
    background:var(--accent);
    margin-top:.45rem; flex-shrink:0;
  }
  .etapa-card.secondary .etapa-bullets li::before{ background:var(--navy); }
  .note-box{
    margin-top:auto;
    background:#fff;
    border-radius:10px;
    padding:1rem 1.2rem;
    font-size:.88rem;
    font-style:italic;
    color:var(--muted);
  }

  /* === Objetivo / Escopo === */
  .kicker{ font-size:1.05rem; color:var(--muted); margin-bottom:.3rem; position:relative; z-index:1;}
  .kicker b{ color:var(--navy); }
  .objective-card{
    background:var(--navy);
    border-radius:14px;
    padding:1.4rem 1.8rem;
    display:flex; gap:1.2rem; align-items:flex-start;
    margin:1.2rem 0 1.6rem;
  }
  .objective-card svg{ width:34px; height:34px; flex-shrink:0; color:var(--accent); margin-top:.2rem;}
  .objective-card h4{ font-size:.85rem; letter-spacing:.2em; color:var(--accent); margin-bottom:.4rem;}
  .objective-card p{ color:var(--ice); font-size:1rem; line-height:1.5; }
  .scope-title{ font-size:1.2rem; font-weight:700; color:var(--navy); margin-bottom:.8rem; }
  .scope-grid{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:.6rem;
  }
  .scope-item{
    display:flex; align-items:center; gap:.7rem;
    background:var(--card);
    border-radius:10px;
    padding:.65rem .9rem;
    font-size:.84rem;
    line-height:1.3;
  }
  .scope-item svg{ width:20px; height:20px; color:var(--accent); flex-shrink:0; }

  /* === Documentos solicitados === */
  .doc-grid{
    display:grid;
    grid-template-columns:repeat(4,1fr);
    gap:1rem;
    margin-top:1.2rem;
  }
  .doc-card{
    background:var(--card);
    border-radius:14px;
    padding:1.2rem 1.1rem;
    display:flex; flex-direction:column; gap:.6rem;
    min-height:150px;
  }
  .doc-icon{
    width:44px;height:44px;border-radius:50%;
    background:var(--navy);
    display:flex;align-items:center;justify-content:center;
    flex-shrink:0;
  }
  .doc-icon svg{ width:22px;height:22px;color:var(--accent); }
  .doc-card h4{ font-size:.95rem; font-weight:700; color:var(--navy); }
  .doc-card p{ font-size:.8rem; color:var(--muted); line-height:1.35; }
  .doc-foot{
    margin-top:1.2rem;
    font-size:.92rem;
    color:var(--muted);
    font-style:italic;
  }

  /* === Questionário Individual === */
  .q-intro{
    background:var(--navy);
    border-radius:14px;
    padding:1.3rem 1.7rem;
    display:flex; gap:1.1rem; align-items:flex-start;
    margin:1.1rem 0 1.3rem;
  }
  .q-intro svg{ width:32px; height:32px; flex-shrink:0; color:var(--accent); margin-top:.2rem;}
  .q-intro h4{ font-size:.8rem; letter-spacing:.2em; color:var(--accent); margin-bottom:.4rem;}
  .q-intro p{ color:var(--ice); font-size:.98rem; line-height:1.5; }

  .id-title{ font-size:1.15rem; font-weight:700; color:var(--navy); margin-bottom:.7rem; }
  .id-grid{
    display:grid;
    grid-template-columns:repeat(4,1fr);
    gap:.8rem;
  }
  .id-card{
    background:var(--card);
    border-radius:12px;
    padding:1.1rem 1.2rem;
    display:flex; flex-direction:column; gap:.5rem;
    border-top:3px solid var(--accent);
  }
  .id-card .id-num{
    width:34px;height:34px;border-radius:50%;
    background:var(--navy);
    color:var(--accent);
    display:flex;align-items:center;justify-content:center;
    font-weight:700; font-size:.95rem;
  }
  .id-card h5{ font-size:1rem; font-weight:700; color:var(--navy); }
  .id-card p{ font-size:.82rem; color:var(--muted); line-height:1.35; }

  /* grid temático de perguntas */
  .q-grid{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:1rem;
    margin-top:1rem;
  }
  .q-card{
    background:var(--card);
    border-radius:14px;
    padding:1.15rem 1.2rem;
    display:flex; flex-direction:column; gap:.7rem;
  }
  .q-head{ display:flex; align-items:center; gap:.7rem; }
  .q-icon{
    width:40px;height:40px;border-radius:50%;
    background:var(--navy);
    display:flex;align-items:center;justify-content:center;
    flex-shrink:0;
  }
  .q-icon svg{ width:20px;height:20px;color:var(--accent); }
  .q-card h4{ font-size:.96rem; font-weight:700; color:var(--navy); line-height:1.2; }
  .q-list{ list-style:none; display:flex; flex-direction:column; gap:.42rem; }
  .q-list li{
    display:flex; gap:.5rem; align-items:flex-start;
    font-size:.8rem; color:var(--text); line-height:1.3;
  }
  .q-list li::before{
    content:"";
    width:6px;height:6px;border-radius:50%;
    background:var(--accent);
    margin-top:.4rem; flex-shrink:0;
  }
  .q-foot{
    margin-top:1.1rem;
    font-size:.9rem;
    color:var(--muted);
    font-style:italic;
  }

  @media (max-width:760px){
    .id-grid{ grid-template-columns:1fr 1fr; }
    .q-grid{ grid-template-columns:1fr; }
  }

  /* === Questionário — Aprofundamento de Governança === */
  .qgov-intro-grid{
    display:grid; grid-template-columns:repeat(3,1fr); gap:1.1rem; margin-top:1.3rem;
  }
  .qgov-pillar{
    background:var(--card); border-radius:14px; padding:1.4rem 1.3rem;
    display:flex; flex-direction:column; gap:.55rem; border-top:4px solid var(--accent);
    min-height:210px;
  }
  .qgov-pillar .pcode{
    font-family:Cambria, serif; font-size:1.6rem; font-weight:700; color:var(--ice);
    line-height:1;
  }
  .qgov-pillar h4{ font-size:1.08rem; font-weight:700; color:var(--navy); }
  .qgov-pillar p{ font-size:.85rem; color:var(--muted); line-height:1.4; }
  .qgov-pillar .qcount{
    margin-top:auto; font-size:.74rem; font-weight:700; letter-spacing:.06em;
    text-transform:uppercase; color:var(--navy);
    display:inline-flex; align-items:center; gap:.45rem;
  }
  .qgov-pillar .qcount::before{
    content:""; width:8px; height:8px; border-radius:50%; background:var(--accent);
  }

  .qgov-grid{
    display:grid; grid-template-columns:1fr 1fr; gap:.55rem 1.4rem; margin-top:1.1rem;
  }
  .qgov-item{
    display:flex; gap:.75rem; align-items:flex-start;
    background:var(--card); border-radius:10px; padding:.65rem .9rem;
  }
  .qgov-num{
    width:26px; height:26px; border-radius:50%;
    background:var(--navy); color:#fff;
    display:flex; align-items:center; justify-content:center;
    font-size:.82rem; font-weight:700; flex-shrink:0;
  }
  .qgov-item p{ font-size:.84rem; color:var(--text); line-height:1.34; }

  @media (max-width:760px){
    .qgov-intro-grid{ grid-template-columns:1fr; }
    .qgov-grid{ grid-template-columns:1fr; }
  }

  /* === Cronograma === */
  .timeline{ display:flex; flex-direction:column; gap:.7rem; margin-top:1rem; }
  .tl-row{
    display:flex; align-items:center; gap:1.4rem;
    background:var(--card);
    border-radius:12px;
    padding:1rem 1.4rem;
  }
  .tl-row.last{
    background:var(--navy);
    color:#fff;
    box-shadow:0 10px 26px rgba(30,39,97,.2);
  }
  .tl-week{
    background:var(--navy);
    color:#fff;
    border-radius:8px;
    padding:.6rem 1.1rem;
    font-weight:700;
    font-size:.95rem;
    min-width:130px;
    text-align:center;
    flex-shrink:0;
  }
  .tl-row.last .tl-week{ background:var(--navy-dark); }
  .tl-text h4{ font-size:1.1rem; font-weight:700; }
  .tl-text p{ font-size:.88rem; color:var(--muted); margin-top:.2rem; }
  .tl-row.last .tl-text p{ color:var(--ice); }

  /* === Entregas === */
  .deliv-grid{
    display:grid;
    grid-template-columns:repeat(4,1fr);
    gap:1.1rem;
    margin-top:1.2rem;
  }
  .deliv-card{
    background:#fff;
    border-radius:14px;
    padding:1.5rem 1.3rem;
    color:var(--text);
    display:flex; flex-direction:column; gap:.7rem;
    min-height:200px;
  }
  .deliv-icon{
    width:50px;height:50px;border-radius:50%;
    background:var(--card);
    display:flex;align-items:center;justify-content:center;
  }
  .deliv-icon svg{ width:26px;height:26px;color:var(--navy); }
  .deliv-card h4{ font-size:1.02rem; font-weight:700; }
  .deliv-card p{ font-size:.85rem; color:var(--muted); }
  .next-step{
    margin-top:1.4rem;
    background:var(--navy-dark);
    border-radius:12px;
    padding:1.1rem 1.5rem;
    display:flex; align-items:center; gap:1rem;
    font-size:1rem;
  }
  .next-step svg{ width:26px;height:26px;color:var(--accent); flex-shrink:0; }
  .next-step b{ color:var(--accent); }

  @media (max-width:760px){
    .etapas{ grid-template-columns:1fr; }
    .scope-grid{ grid-template-columns:1fr; }
    .deliv-grid{ grid-template-columns:1fr 1fr; }
    .badge-row{ gap:1rem; }
    .etapa-days{ margin-top:0; }
    .doc-grid{ grid-template-columns:1fr; }
  }

  /* === Slide embutido: Diagnóstico ao vivo === */
  .slide.embed{
    padding:0;
    background:#00131D;
  }
  .embed-live{
    position:absolute; top:1.1vh; right:6vw; z-index:3;
    display:inline-flex; align-items:center; gap:.5rem;
    font-size:.66rem; letter-spacing:.18em; text-transform:uppercase;
    color:var(--cs-cyan); pointer-events:none;
    background:rgba(0,19,29,.6); padding:.35rem .7rem; border-radius:999px;
    border:1px solid rgba(0,165,221,.3);
  }
  .embed-live::before{
    content:""; width:8px; height:8px; border-radius:50%; background:var(--cs-cyan);
    animation:livePulse 2s infinite;
  }
  @keyframes livePulse{ 0%{box-shadow:0 0 0 0 rgba(0,165,221,.55);} 70%{box-shadow:0 0 0 9px rgba(0,165,221,0);} 100%{box-shadow:0 0 0 0 rgba(0,165,221,0);} }
  .diag-frame{
    border:0; width:100%; height:calc(100% - 7vh); display:block; background:#00131D;
  }

  /* === Animations === */
  @keyframes fadeUp{
    from{ opacity:0; transform:translateY(22px); }
    to{ opacity:1; transform:translateY(0); }
  }
  @keyframes popIn{
    0%{ opacity:0; transform:scale(.4) rotate(-25deg); }
    60%{ opacity:1; transform:scale(1.18) rotate(6deg); }
    100%{ opacity:1; transform:scale(1) rotate(0); }
  }
  @keyframes ringPulse{
