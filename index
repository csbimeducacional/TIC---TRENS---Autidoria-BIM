  .item-main .check{ font-size:.8rem; color:var(--muted); margin-top:.2rem; }
  .note-btn{
    margin-top:.5rem; font-size:.74rem; color:var(--cyan); background:none; border:none;
    cursor:pointer; padding:0; font-family:var(--sans); display:inline-flex; gap:.3rem; align-items:center;
  }
  .note-btn:hover{ text-decoration:underline; }
  .note-wrap{ margin-top:.5rem; display:none; }
  .item.note-open .note-wrap{ display:block; }
  .note-wrap textarea{
    width:100%; min-height:54px; resize:vertical;
    background:var(--navy-2); color:var(--ink); border:1px solid var(--line);
    border-radius:8px; padding:.5rem .6rem; font-family:var(--sans); font-size:.82rem;
  }
  .note-wrap textarea:focus-visible{ outline:2px solid var(--cyan); outline-offset:1px; }

  .sev-group{ display:flex; gap:.35rem; flex-shrink:0; }
  .sev{
    font-size:.74rem; font-weight:600; font-family:var(--mono);
    border:1px solid var(--line); background:#082534; color:var(--muted);
    border-radius:8px; padding:.32rem .5rem; cursor:pointer;
    transition:all .15s; white-space:nowrap;
  }
  .sev:hover{ color:var(--ink); border-color:#2a5670; }
  .sev:focus-visible{ outline:2px solid var(--cyan); outline-offset:1px; }
  .sev.on[data-v=&quot;ok&quot;]{ background:rgba(45,212,167,.16); border-color:var(--ok); color:#9DF0DA; }
  .sev.on[data-v=&quot;warn&quot;]{ background:rgba(245,166,35,.16); border-color:var(--warn); color:#FBD79A; }
  .sev.on[data-v=&quot;crit&quot;]{ background:rgba(255,84,112,.16); border-color:var(--crit); color:#FFB3C0; }
  .sev.on[data-v=&quot;na&quot;]{ background:rgba(91,118,137,.2); border-color:var(--na); color:#BFD2DE; }

  /* filter mode */
  .filtering .item[data-sev=&quot;ok&quot;],
  .filtering .item[data-sev=&quot;na&quot;],
  .filtering .item[data-sev=&quot;pending&quot;]{ display:none; }
  .filtering .pillar.empty-when-filtered .pillar-body::after{
    content:&quot;Nenhum ponto de atenção ou crítico neste eixo.&quot;; display:block;
    color:var(--muted); font-size:.85rem; padding:.6rem 0;
  }

  footer{ margin-top:2.4rem; color:var(--muted); font-size:.78rem; line-height:1.6; }
  footer .legend{ display:flex; flex-wrap:wrap; gap:1rem; margin-bottom:.7rem; }
  footer .leg{ display:inline-flex; align-items:center; gap:.4rem; }
  footer .dot{ width:10px;height:10px;border-radius:3px; }

  .toast{
    position:fixed; bottom:1.4rem; left:50%; transform:translateX(-50%) translateY(20px);
    background:var(--cyan); color:var(--navy-2); font-weight:700; font-size:.85rem;
    padding:.6rem 1.1rem; border-radius:10px; opacity:0; pointer-events:none;
    transition:opacity .25s, transform .25s; z-index:60;
  }
  .toast.show{ opacity:1; transform:translateX(-50%) translateY(0); }

  @media (max-width:640px){
    .item{ grid-template-columns:5px 1fr; }
    .sev-group{ grid-column:2; margin-top:.5rem; flex-wrap:wrap; }
    .stats{ margin-left:0; width:100%; justify-content:flex-start; gap:2rem; }
    .pillar-meta .mini-track{ display:none; }
  }
  @media (prefers-reduced-motion:reduce){
    *{ transition:none !important; }
  }

  /* print */
  @media print{
    body{ background:#fff; color:#10222e; }
    .toolbar,.note-btn,.sev:not(.on),.chev,.toast{ display:none !important; }
    .pillar.collapsed .pillar-body{ display:block !important; }
    .summary,.pillar,.item,.surface{ break-inside:avoid; }
    .pillar,.summary{ border-color:#cdd; }
    .index-num,.mono{ color:#10222e; }
  }
</style>
</head>
<body>
<div class=&quot;wrap&quot;>

  <div class=&quot;brandbar&quot;>
    <b>CSBIM</b><span class=&quot;sep&quot;></span><span>Diagnóstico de Governança BIM</span><span class=&quot;sep&quot;></span><span>TIC TRENS</span>
  </div>
  <div class=&quot;eyebrow&quot;>Etapa 01 · Mapeamento AS-IS</div>
  <h1>Onde a governança mais dói</h1>
  <p class=&quot;lede&quot;>Avalie cada ponto por severidade. O índice de risco e o ranking abaixo se reorganizam em tempo real, mostrando qual eixo — e quais itens — concentram os maiores problemas de governança.</p>

  <!-- ===== Signature: índice + ranking ===== -->
  <section class=&quot;summary&quot; aria-label=&quot;Resumo do diagnóstico&quot;>
    <div class=&quot;summary-top&quot;>
      <div class=&quot;index-block&quot;>
        <span class=&quot;index-num&quot; id=&quot;indexNum&quot;>0</span><span class=&quot;index-pct&quot;>/100</span>
        <div class=&quot;index-meta&quot; style=&quot;margin-left:.6rem&quot;>
          <span class=&quot;index-label&quot;>Índice de risco</span>
          <span class=&quot;index-tag&quot; id=&quot;indexTag&quot;>Aguardando avaliação</span>
        </div>
      </div>
      <div class=&quot;stats&quot;>
        <div class=&quot;stat&quot;><div class=&quot;v&quot; id=&quot;statDone&quot;>0/24</div><div class=&quot;k&quot;>Itens avaliados</div></div>
        <div class=&quot;stat&quot;><div class=&quot;v crit&quot; id=&quot;statCrit&quot;>0</div><div class=&quot;k&quot;>Críticos</div></div>
        <div class=&quot;stat&quot;><div class=&quot;v&quot; id=&quot;statWarn&quot;>0</div><div class=&quot;k&quot;>Atenção</div></div>
      </div>
    </div>

    <div class=&quot;rank-title&quot;>Concentração de problemas por eixo</div>
    <div class=&quot;rank&quot; id=&quot;rank&quot;></div>
  </section>

  <!-- ===== Toolbar ===== -->
  <div class=&quot;toolbar&quot;>
    <button class=&quot;btn toggle&quot; id=&quot;filterBtn&quot; aria-pressed=&quot;false&quot;>▣ Só problemas</button>
    <button class=&quot;btn ghost&quot; id=&quot;expandBtn&quot;>Expandir tudo</button>
    <span class=&quot;spacer&quot;></span>
    <span class=&quot;saved&quot; id=&quot;savedNote&quot;></span>
    <button class=&quot;btn&quot; id=&quot;copyBtn&quot;>⧉ Copiar resumo</button>
    <button class=&quot;btn&quot; id=&quot;printBtn&quot;>⎙ Imprimir / PDF</button>
    <button class=&quot;btn ghost danger&quot; id=&quot;resetBtn&quot;>Limpar</button>
  </div>

  <!-- ===== Pillars ===== -->
  <main id=&quot;pillars&quot;></main>

  <footer>
    <div class=&quot;legend&quot;>
      <span class=&quot;leg&quot;><span class=&quot;dot&quot; style=&quot;background:var(--ok)&quot;></span>Conforme — prática adequada</span>
      <span class=&quot;leg&quot;><span class=&quot;dot&quot; style=&quot;background:var(--warn)&quot;></span>Atenção — parcial / inconsistente</span>
      <span class=&quot;leg&quot;><span class=&quot;dot&quot; style=&quot;background:var(--crit)&quot;></span>Crítico — ausente / risco alto</span>
      <span class=&quot;leg&quot;><span class=&quot;dot&quot; style=&quot;background:var(--na)&quot;></span>N/A — não se aplica</span>
    </div>
    Referência: estados de informação conforme ISO 19650 (Trabalho em progresso · Compartilhado · Publicado · Arquivado). Os dados ficam salvos apenas neste navegador; use “Copiar resumo” ou “Imprimir / PDF” para registrar os achados.
  </footer>
</div>

<div class=&quot;toast&quot; id=&quot;toast&quot;></div>

<script>
const PILLARS = [
  {
    id:&quot;arquivos&quot;, code:&quot;01&quot;, name:&quot;Arquivos&quot;,
    sub:&quot;Nomenclatura, versão, status e saúde dos arquivos&quot;,
    items:[
      [&quot;arq1&quot;,&quot;Nomenclatura padronizada&quot;,&quot;Convenção única e consistente (Projeto-Originador-Volume-Tipo-Disciplina-Nº); sem nomes livres.&quot;],
      [&quot;arq2&quot;,&quot;Versionamento e revisão&quot;,&quot;Códigos de revisão/status claros; sem “final_v2_OK_real”.&quot;],
      [&quot;arq3&quot;,&quot;Status de adequação (suitability)&quot;,&quot;Códigos S0/S1/S2… aplicados e coerentes com o uso permitido.&quot;],
      [&quot;arq4&quot;,&quot;Duplicidade e arquivos órfãos&quot;,&quot;Sem cópias paralelas nem arquivos sem dono/disciplina.&quot;],
      [&quot;arq5&quot;,&quot;Formatos de entrega&quot;,&quot;Nativo, IFC e PDF conforme o exigido em cada fase.&quot;],
      [&quot;arq6&quot;,&quot;Saúde dos modelos&quot;,&quot;Purge/audit feitos; arquivos não inchados; vínculos e coordenadas corretos.&quot;],
      [&quot;arq7&quot;,&quot;Permissões de edição&quot;,&quot;Quem pode alterar cada arquivo está controlado.&quot;]
    ]
  },
  {
    id:&quot;matriz&quot;, code:&quot;02&quot;, name:&quot;Matriz de Informação (LOD/LOI)&quot;,
    sub:&quot;Nível de desenvolvimento e de informação por disciplina e fase&quot;,
    items:[
      [&quot;mtz1&quot;,&quot;Existência e acesso&quot;,&quot;Matriz vigente, versionada e disponível a toda a equipe.&quot;],
      [&quot;mtz2&quot;,&quot;Cobertura por disciplina&quot;,&quot;Todas as disciplinas mapeadas, sem lacunas.&quot;],
      [&quot;mtz3&quot;,&quot;Cobertura por fase&quot;,&quot;Níveis definidos para cada etapa do projeto.&quot;],
      [&quot;mtz4&quot;,&quot;LOD x LOI diferenciados&quot;,&quot;Geometria (LOD) e informação (LOI) tratadas separadamente.&quot;],
      [&quot;mtz5&quot;,&quot;Responsável por elemento&quot;,&quot;Quem entrega cada informação está definido.&quot;],
      [&quot;mtz6&quot;,&quot;Aderência ao requisito (EIR/AIR)&quot;,&quot;Alinhada aos requisitos de informação do contratante.&quot;],
      [&quot;mtz7&quot;,&quot;Rastreabilidade&quot;,&quot;O que está modelado corresponde ao LOD/LOI acordado (amostragem).&quot;],
      [&quot;mtz8&quot;,&quot;Atualização&quot;,&quot;Revisada conforme o projeto evolui.&quot;]
    ]
  },
  {
    id:&quot;estados&quot;, code:&quot;03&quot;, name:&quot;Estados de Informação / Pastas (CDE)&quot;,
    sub:&quot;Organização do ambiente comum de dados (WIP · Compartilhado · Publicado · Arquivado)&quot;,
    items:[
      [&quot;est1&quot;,&quot;Estrutura por estado&quot;,&quot;Pastas refletem os 4 estados: WIP, Compartilhado, Publicado, Arquivado.&quot;],
      [&quot;est2&quot;,&quot;WIP isolado&quot;,&quot;Trabalho em progresso separado por equipe/disciplina, não exposto.&quot;],
      [&quot;est3&quot;,&quot;Compartilhado coordenado&quot;,&quot;Modelos com status de adequação antes de compartilhar.&quot;],
      [&quot;est4&quot;,&quot;Publicado congelado&quot;,&quot;Aprovado para uso/obra, em somente leitura.&quot;],
      [&quot;est5&quot;,&quot;Arquivado preservado&quot;,&quot;Histórico mantido, versionado e não editável.&quot;],
      [&quot;est6&quot;,&quot;Transições controladas&quot;,&quot;Gates de aprovação para mover entre estados.&quot;],
      [&quot;est7&quot;,&quot;Permissões por estado&quot;,&quot;Acessos coerentes com cada estado de informação.&quot;],
      [&quot;est8&quot;,&quot;Nomenclatura de pastas&quot;,&quot;Padrão previsível; sem “pastas selvagens” por empresa.&quot;],
      [&quot;est9&quot;,&quot;Workflow documentado&quot;,&quot;Quem move WIP→Compartilhado→Publicado está definido.&quot;]
    ]
  }
];

const SEV_W = { ok:0, warn:1, crit:2 };           // peso de severidade
const TOTAL = PILLARS.reduce((n,p)=>n+p.items.length,0);
const STORE_KEY = &quot;csbim_gov_tictrens_v1&quot;;
let state = {};   // itemId -> { sev, note }

function load(){
  try{ const raw = localStorage.getItem(STORE_KEY); if(raw) state = JSON.parse(raw)||{}; }catch(e){}
}
function save(){
  try{ localStorage.setItem(STORE_KEY, JSON.stringify(state)); setSaved(&quot;Salvo neste navegador&quot;); }
  catch(e){ setSaved(&quot;Sessão não persistente&quot;); }
}
let savedTimer;
function setSaved(t){
  const el = document.getElementById(&quot;savedNote&quot;);
  el.textContent = t;
  clearTimeout(savedTimer);
  savedTimer = setTimeout(()=> el.textContent=&quot;&quot;, 2200);
}

/* ---------- build DOM ---------- */
load();
const pillarsEl = document.getElementById(&quot;pillars&quot;);
PILLARS.forEach(p=>{
  const sec = document.createElement(&quot;section&quot;);
  sec.className = &quot;pillar&quot;; sec.dataset.pid = p.id;
  sec.innerHTML = `
    <div class=&quot;pillar-head&quot; role=&quot;button&quot; tabindex=&quot;0&quot; aria-expanded=&quot;true&quot;>
      <span class=&quot;pillar-code&quot;>${p.code}</span>
      <div>
        <div class=&quot;pillar-name&quot;>${p.name}</div>
        <div class=&quot;pillar-sub&quot;>${p.sub}</div>
      </div>
      <div class=&quot;pillar-meta&quot;>
        <div class=&quot;mini-track&quot;><div class=&quot;mini-fill&quot; data-pf=&quot;${p.id}&quot;></div></div>
        <span class=&quot;pillar-pct&quot; data-pp=&quot;${p.id}&quot;>—</span>
        <svg class=&quot;chev&quot; width=&quot;14&quot; height=&quot;14&quot; viewBox=&quot;0 0 16 16&quot; fill=&quot;currentColor&quot;><path d=&quot;M8 11L2 5h12z&quot;/></svg>
      </div>
    </div>
    <div class=&quot;pillar-body&quot;></div>`;
  const body = sec.querySelector(&quot;.pillar-body&quot;);
  p.items.forEach(([id,label,check])=>{
    const it = document.createElement(&quot;div&quot;);
    it.className = &quot;item&quot;; it.dataset.itemId = id; it.dataset.sev = &quot;pending&quot;;
    it.innerHTML = `
      <div class=&quot;sev-stripe&quot;></div>
      <div class=&quot;item-main&quot;>
        <h4>${label}</h4>
        <div class=&quot;check&quot;>${check}</div>
        <button class=&quot;note-btn&quot; type=&quot;button&quot;>✎ Observação</button>
        <div class=&quot;note-wrap&quot;><textarea placeholder=&quot;Evidência, exemplo ou recomendação…&quot;></textarea></div>
      </div>
      <div class=&quot;sev-group&quot; role=&quot;group&quot; aria-label=&quot;Severidade de ${label}&quot;>
        <button class=&quot;sev&quot; data-v=&quot;ok&quot;   title=&quot;Conforme&quot;>OK</button>
        <button class=&quot;sev&quot; data-v=&quot;warn&quot; title=&quot;Atenção&quot;>Atenção</button>
        <button class=&quot;sev&quot; data-v=&quot;crit&quot; title=&quot;Crítico&quot;>Crítico</button>
        <button class=&quot;sev&quot; data-v=&quot;na&quot;   title=&quot;Não se aplica&quot;>N/A</button>
      </div>`;
    body.appendChild(it);

    // restore
    const saved = state[id];
    if(saved){
      if(saved.sev){ it.dataset.sev = saved.sev; const b = it.querySelector(`.sev[data-v=&quot;${saved.sev}&quot;]`); if(b) b.classList.add(&quot;on&quot;); }
      if(saved.note){ const ta = it.querySelector(&quot;textarea&quot;); ta.value = saved.note; if(saved.note.trim()) it.classList.add(&quot;note-open&quot;); }
    }

    // severity handlers
    it.querySelectorAll(&quot;.sev&quot;).forEach(btn=>{
      btn.addEventListener(&quot;click&quot;, ()=>{
        const v = btn.dataset.v;
        const cur = it.dataset.sev;
        const isOff = cur === v; // clicking active again clears it
        it.querySelectorAll(&quot;.sev&quot;).forEach(b=>b.classList.remove(&quot;on&quot;));
        if(isOff){ it.dataset.sev = &quot;pending&quot;; delete (state[id]||{}).sev; if(state[id]) state[id].sev=null; }
        else { it.dataset.sev = v; btn.classList.add(&quot;on&quot;); state[id] = Object.assign({}, state[id], {sev:v}); }
        save(); refresh();
      });
    });
    // note handlers
    it.querySelector(&quot;.note-btn&quot;).addEventListener(&quot;click&quot;, ()=>{
      it.classList.toggle(&quot;note-open&quot;);
      if(it.classList.contains(&quot;note-open&quot;)) it.querySelector(&quot;textarea&quot;).focus();
    });
    it.querySelector(&quot;textarea&quot;).addEventListener(&quot;input&quot;, e=>{
      state[id] = Object.assign({}, state[id], {note:e.target.value});
      save();
    });
  });

  // collapse toggle
  const head = sec.querySelector(&quot;.pillar-head&quot;);
  const toggle = ()=>{ sec.classList.toggle(&quot;collapsed&quot;); head.setAttribute(&quot;aria-expanded&quot;, String(!sec.classList.contains(&quot;collapsed&quot;))); };
  head.addEventListener(&quot;click&quot;, toggle);
  head.addEventListener(&quot;keydown&quot;, e=>{ if(e.key===&quot;Enter&quot;||e.key===&quot; &quot;){ e.preventDefault(); toggle(); } });

  pillarsEl.appendChild(sec);
});

/* ---------- scoring ---------- */
function pillarStats(p){
  let assessed=0, weight=0, crit=0, warn=0;
  p.items.forEach(([id])=>{
    const s = state[id] &amp;&amp; state[id].sev;
    if(s &amp;&amp; s!==&quot;na&quot; &amp;&amp; SEV_W.hasOwnProperty(s)){ assessed++; weight += SEV_W[s]; if(s===&quot;crit&quot;) crit++; if(s===&quot;warn&quot;) warn++; }
  });
  const risk = assessed ? Math.round((weight/(assessed*2))*100) : null;
  return {assessed, weight, crit, warn, risk};
}
function riskColor(r){
  if(r===null) return &quot;#2a5670&quot;;
  if(r<20) return &quot;var(--ok)&quot;;
  if(r<45) return &quot;#7FD17A&quot;;
  if(r<70) return &quot;var(--warn)&quot;;
  return &quot;var(--crit)&quot;;
}
function riskTag(r){
  if(r===null) return &quot;Aguardando avaliação&quot;;
  if(r<20) return &quot;Baixo&quot;;
  if(r<45) return &quot;Moderado&quot;;
  if(r<70) return &quot;Alto&quot;;
  return &quot;Crítico&quot;;
}

function refresh(){
  let totAssessed=0, totWeight=0, totCrit=0, totWarn=0;
  const rows = [];

  PILLARS.forEach(p=>{
    const st = pillarStats(p);
    totAssessed += st.assessed; totWeight += st.weight; totCrit += st.crit; totWarn += st.warn;
    // mini bar in head
    const mf = document.querySelector(`.mini-fill[data-pf=&quot;${p.id}&quot;]`);
    const pp = document.querySelector(`.pillar-pct[data-pp=&quot;${p.id}&quot;]`);
    mf.style.width = (st.risk===null?0:st.risk)+&quot;%&quot;;
    mf.style.background = riskColor(st.risk);
    pp.textContent = st.risk===null ? &quot;—&quot; : st.risk+&quot;%&quot;;
    rows.push({p, st});
    // empty-when-filtered marker
    const sec = document.querySelector(`.pillar[data-pid=&quot;${p.id}&quot;]`);
    const visible = p.items.some(([id])=>{ const s=state[id]&amp;&amp;state[id].sev; return s===&quot;warn&quot;||s===&quot;crit&quot;; });
    sec.classList.toggle(&quot;empty-when-filtered&quot;, !visible);
  });

  // overall index
  const overall = totAssessed ? Math.round((totWeight/(totAssessed*2))*100) : null;
  const numEl = document.getElementById(&quot;indexNum&quot;);
  numEl.textContent = overall===null ? &quot;0&quot; : overall;
  numEl.style.color = riskColor(overall);
  document.getElementById(&quot;indexTag&quot;).textContent = riskTag(overall);
  document.getElementById(&quot;indexTag&quot;).style.color = riskColor(overall);
  document.getElementById(&quot;statDone&quot;).textContent = totAssessed + &quot;/&quot; + TOTAL;
  document.getElementById(&quot;statCrit&quot;).textContent = totCrit;
  document.getElementById(&quot;statWarn&quot;).textContent = totWarn;

  // ranking (worst on top; unassessed sink to bottom)
  rows.sort((a,b)=>{
    const ra = a.st.risk===null?-1:a.st.risk, rb = b.st.risk===null?-1:b.st.risk;
    if(rb!==ra) return rb-ra;
    return b.st.crit-a.st.crit;
  });
  const rankEl = document.getElementById(&quot;rank&quot;);
  rankEl.innerHTML = &quot;&quot;;
  rows.forEach((r,i)=>{
    const flagColor = riskColor(r.st.risk);
    const flagTxt = r.st.risk===null ? &quot;sem dados&quot;
      : (r.st.crit>0 ? r.st.crit+&quot; crítico&quot;+(r.st.crit>1?&quot;s&quot;:&quot;&quot;) : riskTag(r.st.risk).toLowerCase());
    const row = document.createElement(&quot;div&quot;);
    row.className = &quot;rank-row&quot;;
    row.innerHTML = `
      <div class=&quot;rank-pos&quot;>${i+1}</div>
      <div class=&quot;rank-bar-wrap&quot;>
        <div class=&quot;rank-bar-head&quot;>
          <span class=&quot;nm&quot;>${r.p.name}</span>
          <span class=&quot;pct&quot;>${r.st.risk===null?&quot;—&quot;:r.st.risk+&quot;%&quot;}</span>
        </div>
        <div class=&quot;rank-track&quot;><div class=&quot;rank-fill&quot; style=&quot;width:${r.st.risk===null?0:r.st.risk}%;background:${flagColor}&quot;></div></div>
      </div>
      <div class=&quot;rank-flag&quot; style=&quot;color:${flagColor};border:1px solid ${flagColor}33;background:${flagColor}14&quot;>${flagTxt}</div>`;
    rankEl.appendChild(row);
  });
}

/* ---------- toolbar actions ---------- */
const filterBtn = document.getElementById(&quot;filterBtn&quot;);
filterBtn.addEventListener(&quot;click&quot;, ()=>{
  const on = document.body.classList.toggle(&quot;filtering&quot;);
  filterBtn.classList.toggle(&quot;on&quot;, on);
  filterBtn.setAttribute(&quot;aria-pressed&quot;, String(on));
});
let allExpanded = true;
document.getElementById(&quot;expandBtn&quot;).addEventListener(&quot;click&quot;, (e)=>{
  allExpanded = !allExpanded;
  document.querySelectorAll(&quot;.pillar&quot;).forEach(s=>{
    s.classList.toggle(&quot;collapsed&quot;, !allExpanded);
    s.querySelector(&quot;.pillar-head&quot;).setAttribute(&quot;aria-expanded&quot;, String(allExpanded));
  });
  e.target.textContent = allExpanded ? &quot;Recolher tudo&quot; : &quot;Expandir tudo&quot;;
});
document.getElementById(&quot;printBtn&quot;).addEventListener(&quot;click&quot;, ()=>window.print());
document.getElementById(&quot;resetBtn&quot;).addEventListener(&quot;click&quot;, ()=>{
  if(!confirm(&quot;Limpar todas as avaliações e observações deste diagnóstico?&quot;)) return;
  state = {}; try{ localStorage.removeItem(STORE_KEY); }catch(e){}
  document.querySelectorAll(&quot;.item&quot;).forEach(it=>{
    it.dataset.sev=&quot;pending&quot;; it.classList.remove(&quot;note-open&quot;);
    it.querySelectorAll(&quot;.sev&quot;).forEach(b=>b.classList.remove(&quot;on&quot;));
    it.querySelector(&quot;textarea&quot;).value=&quot;&quot;;
  });
  refresh(); toast(&quot;Diagnóstico limpo&quot;);
});

const SEV_LABEL = { ok:&quot;Conforme&quot;, warn:&quot;Atenção&quot;, crit:&quot;Crítico&quot;, na:&quot;N/A&quot; };
document.getElementById(&quot;copyBtn&quot;).addEventListener(&quot;click&quot;, ()=>{
  let out = &quot;DIAGNÓSTICO DE GOVERNANÇA BIM — TIC TRENS (CSBIM)\n&quot;;
  out += &quot;Data: &quot; + new Date().toLocaleDateString(&quot;pt-BR&quot;) + &quot;\n&quot;;
  let tA=0,tW=0,tC=0,tWt=0;
  PILLARS.forEach(p=>{ const s=pillarStats(p); tA+=s.assessed; tW+=s.warn; tC+=s.crit; tWt+=s.weight; });
  const ov = tA? Math.round((tWt/(tA*2))*100):0;
  out += `Índice de risco: ${ov}/100 (${riskTag(tA?ov:null)}) · Avaliados ${tA}/${TOTAL} · ${tC} críticos · ${tW} atenção\n`;
  out += &quot;&quot;.padEnd(60,&quot;=&quot;) + &quot;\n&quot;;
  const ranked = PILLARS.map(p=>({p,st:pillarStats(p)})).sort((a,b)=>((b.st.risk||-1)-(a.st.risk||-1)));
  ranked.forEach(({p,st})=>{
    out += `\n[${p.code}] ${p.name} — risco ${st.risk===null?&quot;s/ dados&quot;:st.risk+&quot;%&quot;} (${st.crit} crít., ${st.warn} aten.)\n`;
    p.items.forEach(([id,label])=>{
      const d = state[id]||{}; if(!d.sev &amp;&amp; !(d.note&amp;&amp;d.note.trim())) return;
      out += `  - ${label}: ${SEV_LABEL[d.sev]||&quot;—&quot;}`;
      if(d.note &amp;&amp; d.note.trim()) out += `  | ${d.note.trim()}`;
      out += &quot;\n&quot;;
    });
  });
  const done = ()=>toast(&quot;Resumo copiado&quot;);
  if(navigator.clipboard &amp;&amp; navigator.clipboard.writeText){
    navigator.clipboard.writeText(out).then(done).catch(()=>fallbackCopy(out,done));
  } else fallbackCopy(out,done);
});
function fallbackCopy(text,cb){
  const ta=document.createElement(&quot;textarea&quot;); ta.value=text; document.body.appendChild(ta);
  ta.select(); try{document.execCommand(&quot;copy&quot;);}catch(e){} ta.remove(); cb&amp;&amp;cb();
}
function toast(msg){
  const t=document.getElementById(&quot;toast&quot;); t.textContent=msg; t.classList.add(&quot;show&quot;);
  clearTimeout(t._t); t._t=setTimeout(()=>t.classList.remove(&quot;show&quot;),1800);
}

/* ---------- init ---------- */
// state restored during build; compute metrics
refresh();
</script>
